# Database (Railway Postgres)
PG_URL=postgresql://user:pass@host:5432/db

# Device auth — Bearer token for Pi WebSocket handshake
DEVICE_API_KEY=change-me-long-random-string

# Optional fallback stream URL when a zone has no streamUrl set
AZURACAST_STREAM_URL=https://radio.doerrschuck.de/listen/fe4eea42-0571-4534-890e-d2a45fda8902/radio.mp3

PORT=3000

# Auth — set SKIP_AUTH=true only for local dev, never in production
SKIP_AUTH=false

# Logto (per LOGTO.md)
LOGTO_ENDPOINT=https://duxpom.logto.app/
LOGTO_APP_ID=your-app-id-here
LOGTO_APP_SECRET=your-app-secret-here
LOGTO_COOKIE_SECRET=random-32-plus-char-string
LOGTO_BASE_URL=https://radio-dj.doerrschuck.de
